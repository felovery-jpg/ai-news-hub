# ============================================
# AI News Hub - Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# ---- SUPABASE (Required) ----
# Get from: https://app.supabase.com/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ---- SITE URL (Required) ----
# Your Vercel deployment URL or custom domain
NEXT_PUBLIC_SITE_URL=https://ainewshub.vercel.app

# ---- SECURITY (Required) ----
# Random secret string to protect the /api/collect endpoint
# Generate: openssl rand -hex 32
CRON_SECRET_KEY=your-random-secret-key-here-make-it-long

# ---- AI SUMMARIZATION (Optional but recommended) ----
# Free tier: 15 RPM, 1500 requests/day
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# ---- SEO (Optional but recommended) ----
# IndexNow for instant Bing/Google indexing
# Generate any random string as your key
INDEXNOW_KEY=your-indexnow-key-here

# Google Search Console verification meta tag value
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code

# Bing Webmaster Tools verification
NEXT_PUBLIC_BING_VERIFICATION=your-bing-verification-code

# ---- MONETIZATION (Optional) ----
# Google AdSense - Get after AdSense approval
# Format: ca-pub-XXXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Ad slot IDs from AdSense dashboard
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=XXXXXXXXXX
